<odoo>

    <record id="view_mrp_production_form_tkt"
            model="ir.ui.view">

        <field name="name">mrp.production.form.tkt</field>

        <field name="model">mrp.production</field>

        <field name="inherit_id"
               ref="mrp.mrp_production_form_view"/>

        <field name="arch" type="xml">

            <xpath expr="//sheet/notebook"
                   position="inside">

                <page string="TKT">

                    <group>
                        <field name="tkt_note"/>
                        <field name="qc_status"/>
                        <field name="machine_code"/>
                    </group>

                </page>

            </xpath>

        </field>

    </record>

</odoo>