# --- Database (Postgres Container) ---
POSTGRES_USER=odoo
POSTGRES_PASSWORD=your_secure_db_password
POSTGRES_DB=postgres

# --- Odoo (Application Container) ---
# The Odoo Docker entrypoint looks for these specific names:
HOST=tkterp-db
USER=odoo
PASSWORD=your_secure_db_password
# Odoo Master Password (used to generate odoo.conf on deploy — NOT read by entrypoint directly)
ADMIN_PASSWORD=your_admin_password

# --- SMTP (Email) ---
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SSL=true
