# --- Database ---
# The database user (e.g., odoo)
POSTGRES_USER=odoo
# The database password (change this!)
POSTGRES_PASSWORD=your_secure_db_password
# The initial database name
POSTGRES_DB=postgres

# --- Odoo ---
# The master password for Odoo database management
ODOO_ADMIN_PASSWORD=your_admin_password
# The hostname of the database container (defined in tkterp-db.container)
ODOO_DB_HOST=tkterp-db
# Must match POSTGRES_USER
ODOO_DB_USER=odoo
# Must match POSTGRES_PASSWORD
ODOO_DB_PASSWORD=your_secure_db_password

# --- SMTP (Email) ---
# The SMTP server address (e.g., smtp.gmail.com)
SMTP_SERVER=
# SMTP port (e.g., 587 for TLS, 465 for SSL)
SMTP_PORT=587
# SMTP username (e.g., your-email@gmail.com)
SMTP_USER=
# SMTP password
SMTP_PASSWORD=
# Use SSL/TLS (true/false)
SMTP_SSL=true
